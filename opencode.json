{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "./.opencode/plugins/ccgs-hooks.ts",
    "@tarquinen/opencode-dcp@latest",
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "command": {
    "hybrid-prototype": {
      "template": "Run the hybrid-prototype skill: load .opencode/skills/hybrid-prototype/SKILL.md and follow the fast-lane prototype workflow. Concept: $ARGUMENTS",
      "description": "Fast-lane prototype for discovery phase — build a playable prototype in 2-3 days with minimal process overhead.",
      "agent": "prototyper"
    }
  },
  "mcp": {
    "aseprite": {
      "type": "local",
      "command": ["python", "-m", "aseprite_mcp"],
      "cwd": "tools/aseprite-mcp",
      "enabled": true,
      "env": {
        "ASEPRITE_PATH": "D:\\ziyuan\\Aseprite\\build\\bin\\aseprite.exe"
      }
    },
    "godot": {
      "type": "local",
      "command": ["npx", "@coding-solo/godot-mcp"],
      "enabled": true,
      "environment": {
        "GODOT_PATH": "{env:GODOT_PATH}",
        "DEBUG": "{env:DEBUG}"
      }
    }
  },
  "permission": {
    "bash": {
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "git rev-parse*": "allow",
      "ls *": "allow",
      "dir *": "allow",
      "python -m json.tool*": "allow",
      "python -m pytest*": "allow",
      "py -m pytest*": "allow",
      "rm -rf *": "deny",
      "git push --force*": "deny",
      "git push -f *": "deny",
      "git reset --hard*": "deny",
      "git clean -f*": "deny",
      "sudo *": "deny",
      "chmod 777*": "deny",
      "*>.env*": "deny",
      "cat *.env*": "deny",
      "type *.env*": "deny"
    },
    "read": {
      "**/.env*": "deny"
    }
  }
}
